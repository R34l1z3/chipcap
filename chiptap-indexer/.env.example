# Server
PORT=3002
NODE_ENV=development

# Database (docker-compose maps host 5433 -> container 5432)
DATABASE_URL=postgresql://chiptap:chiptap_secret@localhost:5433/chiptap_pvp_db

# Blockchain RPC (WebSocket required for event listening)
RPC_WS=ws://127.0.0.1:8545
RPC_HTTP=http://127.0.0.1:8545

# For Amoy testnet:
# RPC_WS=wss://polygon-amoy-bor-rpc.publicnode.com
# RPC_HTTP=https://rpc-amoy.polygon.technology

# For Polygon mainnet:
# RPC_WS=wss://polygon-bor-rpc.publicnode.com
# RPC_HTTP=https://polygon-rpc.com

# Contract addresses (update after deploy)
CHIP_NFT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
BATTLE_ARENA_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# Indexer config
START_BLOCK=0
CONFIRMATIONS=3
POLL_INTERVAL_MS=5000

# WebSocket
WS_PORT=3003
