# Server
PORT=3002
NODE_ENV=development
WS_PORT=3003

# Database (docker-compose maps host POSTGRES_PORT -> container 5432)
# SEC-17: the password is now required by docker-compose.  Override
# every credential here in prod; the defaults below are dev-only.
POSTGRES_USER=chiptap
POSTGRES_PASSWORD=chiptap_secret
POSTGRES_DB=chiptap_pvp_db
POSTGRES_PORT=5433
DATABASE_URL=postgresql://chiptap:chiptap_secret@localhost:5433/chiptap_pvp_db

# Solana RPC.
# localnet:
SOLANA_RPC=http://127.0.0.1:8899
SOLANA_WS=ws://127.0.0.1:8900
# devnet:
# SOLANA_RPC=https://api.devnet.solana.com
# SOLANA_WS=wss://api.devnet.solana.com
# Helius/QuickNode example:
# SOLANA_RPC=https://your-rpc.helius-rpc.com/?api-key=...
# SOLANA_WS=wss://your-rpc.helius-rpc.com/?api-key=...

# Program IDs (must match Anchor.toml after `anchor deploy`)
CHIP_NFT_PROGRAM=5opz7a9RhLLDtsqXsMxWsiuJp9Nnz71nUHkQFqv3SFGT
BATTLE_ARENA_PROGRAM=Ae65nkzg2DD4dFUttxUXPpVfZT7kMPX1L9Uk9GDxkBU8
TREASURY_PROGRAM=wGAqdvJJV2DTHUgkDxdMkWotTvg8Q7r5kz5NntWESPp

# How far back to backfill on first run.  `null` = since deploy (slot 0 in
# practice on local; ~recent for devnet).  Set to a slot number for prod.
START_SLOT=0

# Polling interval for backfill (ms)
POLL_INTERVAL_MS=5000

# Max signatures fetched per backfill batch (Solana caps at 1000)
BACKFILL_BATCH_SIZE=200

# ============================================================
# WS broadcast hardening (SEC-13).  In dev all of these are
# safe defaults; for production tighten the token and limits.
# ============================================================
# Shared token clients must present (?token=… in the WS URL).
# Empty = anonymous (dev only).  Set the SAME value in the
# frontend's VITE_WS_TOKEN.
WS_TOKEN=
WS_MAX_CLIENTS=200
WS_MAX_BUFFERED_BYTES=1048576
WS_PING_MS=30000

# ============================================================
# Events table retention (SEC-16).  Keep N days of raw events for
# debug/replay; the indexer's correctness state lives in the other
# tables (chips, battles, player_stats) and isn't touched by pruning.
# Set EVENTS_RETENTION_DAYS=0 to disable pruning entirely.
# ============================================================
EVENTS_RETENTION_DAYS=30
EVENTS_RETENTION_INTERVAL_MS=21600000   # 6h
