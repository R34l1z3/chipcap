# ============================================================
# chiptap-solana-relayer
# ============================================================
#
# Subscribes to BattleJoined events from battle_arena and auto-calls
# fulfill_random_words(seed) as the registered vrf_authority.  This
# removes the "owner has to be online with a CLI" footgun.
#
# Trust model: this is SWITCHBOARD.md "Option A" — trusted relayer.
# The relayer's keypair IS the vrf_authority, so it can technically
# pick any seed; the value here is automating away human-in-the-loop.
# Real trustless random comes in Option B (on-chain Switchboard
# verification) — see SWITCHBOARD.md.
# ============================================================

# Solana endpoint.  Localnet / devnet / mainnet — same shape.
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_WS=wss://api.devnet.solana.com

# Keypair file path (Solana CLI format — same JSON as ~/.config/solana/id.json).
# This wallet MUST be the registered vrf_authority on battle_arena AND
# have enough SOL for tx fees (rare — fulfill_random_words is a small
# tx, ~5_000 lamports each).
VRF_AUTHORITY_KEYPAIR=/root/.config/solana/id.json

# Program ID (Anchor.toml [programs.devnet]).
BATTLE_ARENA_PROGRAM=Ae65nkzg2DD4dFUttxUXPpVfZT7kMPX1L9Uk9GDxkBU8

# Randomness source.  Two implementations:
#   - slothash : derive seed from a recent slothash + battle_id.
#                Deterministic from chain state, free, no oracle.
#                Validator-leader could theoretically influence; fine
#                for low-stake bets.
#   - switchboard : fetch from Switchboard On-Demand (devnet/mainnet
#                only).  Better trust, costs ~0.001 SOL per VRF.
#                NOT YET IMPLEMENTED — slothash is the active path.
RANDOMNESS_SOURCE=slothash

# How long to wait after BattleJoined before submitting the fulfill.
# Lets the program transition to ROLLING and gives the loser a moment
# to see the popup before the result flashes by.  Tune to taste.
FULFILL_DELAY_MS=3000

# Polling fallback interval — if onLogs subscription dies, the relayer
# polls getSignaturesForAddress every N ms to catch up.
POLL_INTERVAL_MS=20000

# Set to 1 for verbose log lines per event.
DEBUG=1
