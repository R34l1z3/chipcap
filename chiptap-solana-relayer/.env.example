# ============================================================
# chiptap-solana-relayer
# ============================================================
#
# Subscribes to two events on battle_arena and dispatches the VRF
# fulfill ix:
#   • BattleJoined           → fulfill_random_words / _switchboard (1v1)
#   • BattleRoyaleRolling    → fulfill_random_words_br_switchboard (SEC-22)
#
# Trust model:
#   • RANDOMNESS_SOURCE=switchboard (default for production) — SEC-21
#     Option B. Switchboard On-Demand signs the randomness; our program
#     verifies the proof on-chain before consuming it. Relayer just
#     pays the SOL fees and coordinates the commit+reveal cycle —
#     it CANNOT pick a favourable seed.
#   • RANDOMNESS_SOURCE=slothash — interim Option A, trusted relayer
#     derives seed from a slothash. 1v1 only; Battle Royale will NOT
#     auto-fulfill in this mode (BR has no slothash ix on chain).
# ============================================================

# Solana endpoint.  Localnet / devnet / mainnet — same shape.
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_WS=wss://api.devnet.solana.com

# Keypair file path (Solana CLI format — same JSON as ~/.config/solana/id.json).
# This wallet MUST be the registered vrf_authority on battle_arena AND
# have enough SOL for tx fees (rare — fulfill_random_words is a small
# tx, ~5_000 lamports each).
VRF_AUTHORITY_KEYPAIR=/root/.config/solana/id.json

# Program ID (Anchor.toml [programs.devnet]).
BATTLE_ARENA_PROGRAM=Ae65nkzg2DD4dFUttxUXPpVfZT7kMPX1L9Uk9GDxkBU8

# Randomness source. Two implementations:
#   - switchboard : Switchboard On-Demand (devnet/mainnet). Full
#                on-chain proof verification (SEC-21 Option B).
#                Costs ~0.001 SOL per VRF in tx + LUT fees.
#                REQUIRED for Battle Royale (SEC-22).
#                **Recommended for production.**
#   - slothash   : derive seed from a recent slothash + battle_id.
#                Trusted-relayer model (SEC-21 Option A interim).
#                Free, no oracle. Validator-leader could theoretically
#                influence; fine for low-stake bets / localnet dev.
#                Does NOT cover Battle Royale.
RANDOMNESS_SOURCE=switchboard

# How long to wait after BattleJoined before submitting the fulfill.
# Lets the program transition to ROLLING and gives the loser a moment
# to see the popup before the result flashes by.  Tune to taste.
FULFILL_DELAY_MS=3000

# Polling fallback interval — if onLogs subscription dies, the relayer
# polls getSignaturesForAddress every N ms to catch up.
POLL_INTERVAL_MS=20000

# Set to 1 for verbose log lines per event.
DEBUG=1
